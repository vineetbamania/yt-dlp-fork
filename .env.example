# Copy to .env and fill in. Never commit .env.

# Static bearer token. Generate with: openssl rand -hex 32
AUTH_TOKEN=

# Port the Nest API listens on. The static web/ is served by the same process.
PORT=8787

# Where yt-dlp writes intermediate + final files. Cleaned per-job.
TMP_DIR=./tmp

# Optional: enable HTTPS via tailscale-issued cert.
# Run `npm run issue-tls` to populate these (it prints the exact values).
# TLS_CERT_PATH=
# TLS_KEY_PATH=

# Optional: comma-separated browser origins allowed to call this API.
# Only needed if the frontend is served from a different origin (e.g.
# GitHub Pages). Same-origin (served by this process) works without it.
# CORS_ORIGINS=https://vineetbamania.github.io
