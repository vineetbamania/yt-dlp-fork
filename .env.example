# Copy to .env and fill in. Never commit .env.

# Static bearer token. Generate with: openssl rand -hex 32
AUTH_TOKEN=

# Port the Nest API listens on. The static web/ is served by the same process.
PORT=8787

# Where yt-dlp writes intermediate + final files. Cleaned per-job.
TMP_DIR=./tmp

# Target MP3 bitrate for sources that must be transcoded (e.g. JioSaavn AAC).
# CBR on purpose, for broad player compatibility.
# AUDIO_BITRATE=192k

# YouTube/Spotify get bot-challenged from datacenter IPs. Supply a Netscape
# cookies.txt to authenticate yt-dlp. Pick ONE (B64 wins if both are set):
#   - path to the file (local / VM / mounted volume):
# YTDLP_COOKIES_FILE=/data/cookies.txt
#   - base64 of the file contents (handy as a Fly.io secret):
#     export it with:  base64 -i cookies.txt | tr -d '\n'
# YTDLP_COOKIES_B64=

# Optional: enable HTTPS via tailscale-issued cert.
# Run `npm run issue-tls` to populate these (it prints the exact values).
# TLS_CERT_PATH=
# TLS_KEY_PATH=

# Optional: comma-separated browser origins allowed to call this API.
# Only needed if the frontend is served from a different origin (e.g.
# GitHub Pages). Same-origin (served by this process) works without it.
# CORS_ORIGINS=https://vineetbamania.github.io
