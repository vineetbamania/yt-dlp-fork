{
  "name": "yt-dlp-fork",
  "version": "0.1.0",
  "private": true,
  "description": "Personal YouTube/media -> MP3 tool. Sideloaded, single-user, Tailscale-only.",
  "workspaces": [
    "api"
  ],
  "scripts": {
    "setup": "bash scripts/check-deps.sh && npm install",
    "check-deps": "bash scripts/check-deps.sh",
    "update-ytdlp": "bash scripts/update-ytdlp.sh",
    "issue-tls": "bash scripts/issue-tls.sh",
    "install-agent": "bash scripts/install-launchd.sh",
    "uninstall-agent": "bash scripts/uninstall-launchd.sh",
    "dev": "npm run start:dev --workspace api",
    "start": "npm run start:prod --workspace api",
    "build": "npm run build --workspace api",
    "lint": "npm run lint --workspace api && prettier --check .",
    "format": "prettier --write .",
    "test": "npm run test --workspace api",
    "test:e2e": "npm run test:e2e --workspace api",
    "typecheck": "npm run typecheck --workspace api",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.4.2"
  }
}
